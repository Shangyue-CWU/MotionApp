<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_summary.xml
    Full-screen Session Summary page — matches HTML mockup Screen 4.

    Place in: app/src/main/res/layout/fragment_summary.xml
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F2FF"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- ── Top bar (matches app's existing top-bar style) ─────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#F3F2FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="20dp">

        <!-- Back button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_stat_chip"
            android:gravity="center"
            android:text="←"
            android:textColor="#2A3FBF"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="MotionWatch"
            android:textColor="#1A1A3E"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <!-- Page heading -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02"
                android:text="Session Summary"
                android:textColor="#1A1A3E"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- ── Meta row ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_stat_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="DATE"
                        android:textAllCaps="true"
                        android:textColor="#7070A8"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvSumDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#1A2480"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="DURATION"
                        android:textAllCaps="true"
                        android:textColor="#7070A8"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvSumDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#1A2480"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Samples -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="SAMPLES"
                        android:textAllCaps="true"
                        android:textColor="#7070A8"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvSumSamples"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#1A2480"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Events -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="EVENTS"
                        android:textAllCaps="true"
                        android:textColor="#7070A8"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvSumEvents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#1A2480"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Motion Breakdown section label ───────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:text="MOTION BREAKDOWN"
                android:textAllCaps="true"
                android:textColor="#3B5BF7"
                android:textSize="10sp" />

            <!-- ── Donut card ─────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <!-- Horizontal: donut left, legend right -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <!-- Donut chart -->
                    <com.example.motionwatch.DonutChartView
                        android:id="@+id/donutChart"
                        android:layout_width="130dp"
                        android:layout_height="130dp" />

                    <!-- Legend -->
                    <LinearLayout
                        android:id="@+id/legendContainer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical"
                        android:gravity="center_vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Detection Log section label ──────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:text="DETECTION LOG"
                android:textAllCaps="true"
                android:textColor="#3B5BF7"
                android:textSize="10sp" />

            <!-- ── Detection log card ────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/detectionLogContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp" />
            </androidx.cardview.widget.CardView>

            <!-- ── Export + Back buttons ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSumExportCsv"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.4"
                    android:background="@drawable/bg_btn_export"
                    android:enabled="false"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:text="↓  Export CSV"
                    android:textColor="#2A3FBF"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btnBackToLive"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_start"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:text="↩  Back to Live"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>