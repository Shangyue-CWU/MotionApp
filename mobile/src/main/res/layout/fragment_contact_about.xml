<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_back"
            android:tint="#111827" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About"
            android:textColor="#111827"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="MotionWatch is an Android-based fitness and motion tracking app that records activity sessions using a phone and wearable device. The app helps users start sessions, collect movement data, and review past activity information."
            android:textColor="#374151"
            android:textSize="14sp" />

        <!-- Team Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Development Team"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Ali -->
        <LinearLayout
            android:id="@+id/cardAli"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:text="A"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="Ali Nizar"
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Kobe -->
        <LinearLayout
            android:id="@+id/cardKobe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:text="K"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="Kobe Takemura"
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Calvin -->
        <LinearLayout
            android:id="@+id/cardCalvin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:text="C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="Calvin Giles"
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Tasha -->
        <LinearLayout
            android:id="@+id/cardTasha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:text="T"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="Tasha Peterson"
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Cindy -->
        <LinearLayout
            android:id="@+id/cardCindy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:text="C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="Cindy Chitsuwa"
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Project Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Project Information"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Version: 1.0"
            android:textColor="#374151"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Platform: Android Mobile + Wearable"
            android:textColor="#374151"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Purpose: Track activity sessions and motion data for review and analysis."
            android:textColor="#374151"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>