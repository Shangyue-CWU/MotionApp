<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact &amp; About"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111827"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Company: Central Solutions\nProduct: MotionWatch Fitness App\nPurpose: Track activity sessions between Android phone and watch."
            android:textColor="#374151"
            android:textSize="14sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Contact:\nEmail: support@centralsolutions.com\nPhone: (000) 000-0000\nLocation: Seattle, WA (placeholder)"
            android:textColor="#374151"
            android:textSize="14sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Version: 1.0"
            android:textColor="#9CA3AF"
            android:textSize="12sp"/>
    </LinearLayout>
</ScrollView>
