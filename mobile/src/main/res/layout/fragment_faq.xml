<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FAQ"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#101828" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap a question to learn more."
            android:textSize="18sp"
            android:textColor="#667085"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/faqStartSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How do I start a session?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#101828"
            android:background="#EEEAE7"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/faqActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Where can I view my activity?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#101828"
            android:background="#EEEAE7"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/faqAnalytics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What does the Analytics page show?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#101828"
            android:background="#EEEAE7"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/faqData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How is my data stored?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#101828"
            android:background="#EEEAE7"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/faqSensors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What sensors does the app use?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#101828"
            android:background="#EEEAE7"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/faqReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How do I reset a live session?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#101828"
            android:background="#EEEAE7"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

    </LinearLayout>
</ScrollView>