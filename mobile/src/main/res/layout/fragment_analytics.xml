<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/analyticsScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvAnalyticsDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTOMATIC RECOGNITION"
            android:textAllCaps="true"
            android:textColor="#8B93A7"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAnalyticsWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Analytics"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Current Recognition Card -->
        <LinearLayout
            android:id="@+id/cardRecognition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#DDE6F2"
            android:orientation="vertical"
            android:padding="20dp"
            android:minHeight="170dp"
            android:gravity="center"
            android:backgroundTint="#DDE6F2">

            <TextView
                android:id="@+id/tvRecognitionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT RECOGNITION"
                android:textAllCaps="true"
                android:textColor="#6E7688"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecognitionIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="◫◫"
                android:textColor="#000000"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Idle"
                android:textColor="#2E64F5"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Confidence: --"
                android:textColor="#4A5568"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Totals -->

        <!-- Session Card -->
        <LinearLayout
            android:id="@+id/cardSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="#DDE6F2"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSessionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANALYTICS SESSION"
                android:textAllCaps="true"
                android:textColor="#8B93A7"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnStartStop"
                    android:layout_width="132dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="14dp"
                    android:backgroundTint="#8EA9A0"
                    android:text="START"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSessionStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="SESSION STATUS"
                android:textAllCaps="true"
                android:textColor="#2E64F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/boxSessionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#E8E8ED"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvSessionState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="State: Idle"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSessionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Duration: 00:00"
                    android:textColor="#333333"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSessionFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Output File: --"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="LIVE RECOGNITION"
                android:textAllCaps="true"
                android:textColor="#2E64F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/boxRecognitionResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#E8E8ED"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvLivePrediction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prediction: Idle"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLiveScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Score: --"
                    android:textColor="#333333"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvLiveHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Waiting for recognition session to start."
                    android:textColor="#666666"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="#D97A7A"
                    android:text="CLEAR"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnSaveCsv"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:enabled="false"
                    android:backgroundTint="#B0B7C3"
                    android:text="SAVE CSV"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnShareCsv"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:enabled="false"
                    android:backgroundTint="#B0B7C3"
                    android:text="SHARE"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>