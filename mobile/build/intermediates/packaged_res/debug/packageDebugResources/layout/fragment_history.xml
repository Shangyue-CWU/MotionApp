<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="#111827"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="History"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_below="@id/btnBack"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tvHistorySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your journey, logged."
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:layout_below="@id/tvHistoryTitle"
            android:layout_marginTop="6dp"/>

        <ImageButton
            android:id="@+id/btn_filter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/tvHistoryTitle"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Filter logs"
            android:src="@drawable/ic_filter"
            app:tint="#10B981" />
    </RelativeLayout>

    <!-- Active Filters Display -->
    <TextView
        android:id="@+id/tv_active_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Showing all logs"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to preview • Long-press to select"
        android:textSize="12sp"
        android:textColor="#6B7280"
        app:layout_constraintTop_toBottomOf="@id/tv_active_filters"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No logs yet."
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_hint"
        android:paddingTop="8dp" />

    <ListView
        android:id="@+id/list_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:choiceMode="multipleChoiceModal"
        android:listSelector="?android:attr/activatedBackgroundIndicator"
        android:divider="?android:attr/listDivider"
        android:dividerHeight="1dp"
        android:scrollbarStyle="outsideInset"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tv_hint"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
