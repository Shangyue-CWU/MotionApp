<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="FEBRUARY 2026"
            android:textAllCaps="true"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <!-- Last tracked motion -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#EAF3FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAST TRACKED MOTION"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/ic_walk"
                    android:contentDescription="Motion Icon" />

                <TextView
                    android:id="@+id/tvLastMotion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Walking"
                    android:textColor="#2563EB"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Detection totals -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DETECTION TOTALS"
            android:textAllCaps="true"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvFallsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Falls"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvTremorsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tremors"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvAbnormalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Abnormal"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Activity log -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVITY LOG"
            android:textAllCaps="true"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F2F7FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Label: Walking"
                        android:textColor="#1D4ED8"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStart"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="START"
                        app:cornerRadius="14dp" />
                </LinearLayout>

                <!-- Accelerometer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCELEROMETER"
                    android:textColor="#2563EB"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvAccX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="X-Axis: --"
                    android:textColor="#111827"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tvAccY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Y-Axis: --"
                    android:textColor="#111827"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvAccZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Z-Axis: --"
                    android:textColor="#111827"
                    android:layout_marginTop="4dp" />

                <!-- Gyroscope -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GYROSCOPE"
                    android:textColor="#2563EB"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvGyroPitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pitch: --"
                    android:textColor="#111827"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tvGyroRoll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Roll: --"
                    android:textColor="#111827"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvGyroYaw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Yaw: --"
                    android:textColor="#111827"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>